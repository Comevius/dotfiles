alias d dired $1
alias f find-file $1
alias e (eshell 'N)
alias t (ansi-term "/bin/sh")
alias pacu sudo pacman -Syu $*
alias paci sudo pacman -S $*
alias pacr sudo pacman -Rsn $*
alias pacq sudo pacman -Q $*
alias mount udisksctl mount -b $*
alias umount udisksctl unmount -b $*
alias untar tar -xf $*
alias du du -h $*
alias df df -h $*
alias free free -m
alias sshf ssh -NfL $1:localhost:$1 other
alias sshf-adb sshf 5037
alias fr flutter run --observatory-port 8100
alias vgle vglconnect -e $1 other
alias vglr vglconnect -e "vglrun $1" other
alias avd vglr "emulator -gpu host avd $1"
alias avds vgle "emulator -list-avds"
