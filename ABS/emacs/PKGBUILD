pkgname=emacs
pkgver=26.1
pkgrel=1
pkgdesc="Emacs text editor"
arch=('x86_64')
url="http://www.gnu.org/software/emacs/emacs.html"
license=('GPL3')
conflicts=('emacs')
depends=('m17n-lib' 'libotf' 'gnutls' 'jansson' 'libxml2' 'libsystemd')
source=("ftp://ftp.gnu.org/gnu/emacs/${pkgname}-${pkgver}.tar.xz"
        "override.conf")
sha256sums=('1cf4fc240cd77c25309d15e18593789c8dbfba5c2b44d8f77c886542300fd32c'
            '4f25a05a1f471f93cea3744a20d88758aa66af5bb582b4f5ca829b2e494fbf9b')

build() {
  cd "$srcdir"/emacs-26.1
  ./configure --program-transform-name='s/^ctags$/ctags.emacs/' \
              --prefix=/usr --sysconfdir=/etc --libexecdir=/usr/lib \
              --localstatedir=/var --without-all --with-x-toolkit=no \
              --with-modules --with-threads \
              --with-libsystemd --with-dbus --with-file-notification=yes \
              --with-xft --with-libotf --with-m17n-flt \
              --with-xml2 --with-json --with-gnutls
  make
}

package() {
  cd "$srcdir"/emacs-26.1
  make DESTDIR="$pkgdir" install
  cd "$srcdir"
  install -D override.conf -t "$pkgdir"/usr/lib/systemd/user/emacs.service.d
}
