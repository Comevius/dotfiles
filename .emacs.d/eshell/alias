alias d dired $1
alias f find-file $1
alias e (eshell 'N)
alias t (ansi-term "/bin/sh")
alias r /bin/rm -rI $*
alias c /bin/cp $*
alias m /bin/mv $*
alias P cd ~/Projects/earlybetter
alias A cd ~/Agenda
alias D cd ~/Downloads
alias pacu sudo pacman -Syu $*
alias paci sudo pacman -S $*
alias pacr sudo pacman -Rsn $*
alias pacq sudo pacman -Q $*
alias pacc sudo pacman -Scc $*
alias mount udisksctl mount -b $*
alias umount udisksctl unmount -b $*
alias untar tar -xf $*
alias du du -h $*
alias df df -h $*
alias free free -m
alias sshl ssh -NfL $1:localhost:$1 other
alias sshr ssh -NfR $1:localhost:$1 other
alias flur flutter run
alias flurp flutter run --profile
alias flurr flutter run --release
alias avd emulator -gpu host -avd $1
alias avds emulator -list-avds
alias encrypt gpg --output $1.gpg --encrypt --recipient comevius@gmail.com $1
alias -dpms xset s off -dpms
alias +dpms xset s reset +dpms
