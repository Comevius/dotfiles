pkgname=emacs
pkgver=27.0.91
pkgrel=1
epoch=1
pkgdesc="Emacs text editor"
arch=('x86_64')
url="http://www.gnu.org/software/emacs/"
license=('GPL3')
depends=('dbus' 'libsystemd' 'gnutls' 'gmp' 'jansson' 'libxml2'
         'cairo' 'harfbuzz')
source=("https://alpha.gnu.org/gnu/emacs/pretest/${pkgname}-${pkgver}.tar.xz")
sha256sums=('96813dd385dec81ceb1868645939d49b81ca2c1feb42a58b4d38125ebd1345aa')

build() {
  cd "$srcdir"/emacs-"$pkgver"
  ./configure --program-transform-name='s/^ctags$/ctags.emacs/' \
              --prefix=/usr --sysconfdir=/etc --libexecdir=/usr/lib \
              --localstatedir=/var --mandir=/usr/share/man \
              --disable-build-details \
              --without-all --with-x-toolkit=no --with-modules --with-threads \
              --with-gnutls --with-libgmp --with-dbus --with-libsystemd \
              --with-file-notification=yes \
              --with-cairo --with-harfbuzz \
              --with-xml2 --with-json
  make
}

package() {
  cd "$srcdir"/emacs-"$pkgver"
  make DESTDIR="$pkgdir" install
}
